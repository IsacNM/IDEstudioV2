-# =====================================================
-# Prueba extra: paréntesis profundos y casos complicados
-# =====================================================
inicio {

    var entero a;
    var entero b;
    var entero c;
    var entero d;
    var entero r;

    a := 2;
    b := 3;
    c := 4;
    d := 5;

    -# Triple anidamiento
    r := ((a + b) * (c - d));

    -# Cuatro niveles de paréntesis
    r := (((a + b) * c) + ((d - a) * b));

    -# Parentesis redundantes
    r := (((((a)))));

    -# Suma de productos con parentesis
    r := (a * b) + (c * d) - (a * d);

    -# Mezcla con módulo y división
    r := ((a + b) % (c - 1)) + ((d * 2) / (a + 1));

    -# Operaciones encadenadas con parentesis multiples
    r := (a + b) * (c + d) - (a - b) * (c - d);

    mostrar(r);

} fin
