n:=5;
total:=0;
promedio:=0.0;
mensaje:="resultado:";
continuar:=cierto;
MOSTRAR "elige una opcion (1..3):";
LEER opcion;
if (opcion<1-o-opcion>3) then GOTO L1;
GOTO L2;
L1:
MOSTRAR "opcion fuera de rango, se usara 1";
opcion:=1;
GOTO L3;
L2:
MOSTRAR "opcion valida";
L3:
if (opcion::1) then GOTO L5;
if (opcion::2) then GOTO L6;
if (opcion::3) then GOTO L7;
GOTO L8;
L5:
i:=1;
L9:
if (i<=n) then GOTO L10;
GOTO L11;
L10:
if (i%2::0) then GOTO L12;
GOTO L13;
L12:
T1:=total+i;
total:=T1;
GOTO L14;
L13:
T2:=total-i;
total:=T2;
L14:
i:=i+1;
GOTO L9;
L11:
MOSTRAR mensaje;
MOSTRAR total;
GOTO L4;
L6:
i:=0;
L15:
if (i<n-y-continuar::cierto) then GOTO L16;
GOTO L17;
L16:
if (i::0) then GOTO L19;
if (i::1) then GOTO L20;
if (i::2) then GOTO L21;
GOTO L22;
L19:
MOSTRAR "cero";
GOTO L18;
L20:
MOSTRAR "uno";
GOTO L18;
L21:
MOSTRAR "dos";
GOTO L18;
L22:
MOSTRAR "otro";
L18:
T3:=i+1;
i:=T3;
GOTO L15;
L17:
GOTO L4;
L7:
T4:=n+2;
T5:=n-1;
T6:=T4*T5;
T7:=T6/2;
total:=T7;
T8:=total/n;
promedio:=T8;
T9:=0&+0;
mensaje:=T9;
MOSTRAR mensaje;
MOSTRAR total;
MOSTRAR promedio;
GOTO L4;
L8:
MOSTRAR "opcion no manejada";
L4:
if (total>0) then GOTO L23;
GOTO L24;
L23:
MOSTRAR "hay valor positivo";
GOTO L25;
L24:
if (total::0) then GOTO L26;
GOTO L27;
L26:
MOSTRAR "total es cero";
GOTO L28;
L27:
MOSTRAR "total negativo";
L28:
L25:
i:=n;
L29:
if (i>0) then GOTO L30;
GOTO L31;
L30:
MOSTRAR i;
i:=i-1;
GOTO L29;
L31:
MOSTRAR "fin del programa";
