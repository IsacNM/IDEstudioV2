MOSTRAR "ingresa tu nombre:";
LEER nombre;
MOSTRAR "ingresa tu apellido:";
LEER apellido;
MOSTRAR "ingresa tu edad:";
LEER edad;
T1:=0&+nombre;
saludo:=T1;
T2:=0&+nombre;
T3:=0&+T2;
T4:=T3&+apellido;
saludo:=T4;
MOSTRAR saludo;
MOSTRAR "tu edad es:";
MOSTRAR edad;
T5:=2026-edad;
anio:=T5;
MOSTRAR "año aproximado de nacimiento:";
MOSTRAR anio;
T6:=edad*12;
MOSTRAR T6;
T7:=edad+10;
T8:=T7*2;
MOSTRAR T8;
inicial:='A';
MOSTRAR inicial;
